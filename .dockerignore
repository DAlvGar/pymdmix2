# Files and directories to exclude from the Docker build context.
# Keep the image lean and avoid accidental inclusion of local state.

# Version control
.git
.gitignore
.github

# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Virtual environments / uv
.venv/
venv/
.uv/
uv.lock

# Test artifacts
.coverage
htmlcov/
*.xml

# Build artifacts
build/
dist/
*.egg-info/

# Docs
docs/

# Editor / OS files
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Singularity image files
*.sif
*.simg

# Temporary files
tmp/
